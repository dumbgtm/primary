---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<BaseLayout title="Blog" description="Contrarian takes on GTM slop and overdone tactics.">
  <section class="max-w-3xl mx-auto px-6 pt-16 pb-24">
    <p class="tag mb-6">updated whenever something annoys us</p>
    <h1 class="font-display font-extrabold text-3xl sm:text-5xl mb-10 leading-tight text-ink">The Blog</h1>

    {posts.length === 0 ? (
      <p class="text-slate">Nothing here yet. Give it a minute.</p>
    ) : (
      <div class="space-y-6">
        {posts.map((post) => (
          <a href={`/blog/${post.slug}`} class="block rounded-xl border border-ink/10 bg-white/40 p-6 hover:bg-frost/20 hover:border-ink/20 transition-colors">
            <p class="text-xs uppercase tracking-wide text-slate mb-2">
              {post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
            </p>
            <h2 class="font-display font-bold text-2xl mb-2 leading-snug text-ink">{post.data.title}</h2>
            <p class="text-ink/70">{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <div class="flex gap-2 mt-4 flex-wrap">
                {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
              </div>
            )}
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
