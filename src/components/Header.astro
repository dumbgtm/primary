---
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Blog' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
];
const currentPath = Astro.url.pathname;
---
<header class="border-b border-ink/10">
  <div class="max-w-5xl mx-auto flex items-center justify-between px-6 py-5">
    <a href="/" class="font-display font-extrabold text-xl sm:text-2xl text-ink lowercase tracking-tight">
      dumb gtm
    </a>
    <nav class="flex items-center gap-1 sm:gap-2">
      {navItems.map((item) => {
        const active = currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href));
        return (
          <a
            href={item.href}
            class:list={[
              'font-display text-sm px-3 py-2 rounded-md transition-colors',
              active ? 'text-siren font-bold' : 'text-ink/70 hover:text-siren',
            ]}
          >
            {item.label}
          </a>
        );
      })}
    </nav>
  </div>
</header>
